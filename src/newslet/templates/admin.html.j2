<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>daily scoop · admin</title>
<style>
  {{ theme_css }}
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; background: var(--bg); color: var(--fg); }
  body {
    font-family: var(--font-body);
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
  }
  .wrap { max-width: 760px; margin: 0 auto; padding: 24px 16px 64px; }
  header.top {
    display: flex; align-items: center; justify-content: space-between;
    padding-bottom: 16px; border-bottom: 1px solid var(--border); margin-bottom: 24px;
  }
  .brand { font-family: var(--font-brand); font-size: 1.375rem; font-weight: 700; letter-spacing: -0.01em; }
  .logout { font-size: 0.8125rem; color: var(--muted); text-decoration: none; }
  .logout:hover { color: var(--fg); text-decoration: underline; }
  section { background: var(--panel); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px; margin-bottom: 24px; }
  h2 { margin: 0 0 16px 0; font-size: 1.125rem; }
  .count { color: var(--muted); font-weight: 400; font-size: 0.875rem; margin-left: 6px; }
  ul.feeds { list-style: none; padding: 0; margin: 0 0 20px 0; }
  ul.feeds li {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 0; border-bottom: 1px solid var(--border); gap: 12px;
  }
  ul.feeds li:last-child { border-bottom: none; }
  .feed-info { min-width: 0; flex: 1; }
  .feed-title { font-weight: 600; word-break: break-word; }
  .feed-url { font-size: 0.75rem; color: var(--muted); word-break: break-all; margin-top: 2px; }
  .feed-added { font-size: 0.6875rem; color: var(--muted); margin-top: 2px; }
  form.inline { display: inline; margin: 0; }
  button, input[type="submit"] {
    font: inherit; cursor: pointer; padding: 6px 12px;
    background: var(--panel); color: var(--fg);
    border: 1px solid var(--border); border-radius: var(--radius-sm);
  }
  button:hover { border-color: var(--accent); }
  button.danger {
    color: var(--bad); background: var(--bad-bg); border-color: var(--bad-border);
  }
  button.primary {
    color: var(--accent-fg); background: var(--accent); border-color: var(--accent);
  }
  .add-form { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; padding-top: 12px; border-top: 1px solid var(--border); }
  .add-form input[type="text"], .add-form input[type="url"] {
    flex: 1; min-width: 180px; padding: 8px 10px;
    background: var(--input-bg); color: var(--fg);
    border: 1px solid var(--border); border-radius: var(--radius-sm); font: inherit;
  }
  textarea {
    width: 100%; padding: 10px; font-family: var(--font-mono);
    font-size: 0.875rem; background: var(--input-bg); color: var(--fg);
    border: 1px solid var(--border); border-radius: var(--radius-sm); resize: vertical;
  }
  .save-row { margin-top: 12px; }
  .empty { color: var(--muted); font-style: italic; padding: 8px 0; }
</style>
</head>
<body>
  <div class="wrap">
    <header class="top">
      <div class="brand">daily scoop · admin</div>
      <div>
        <a class="logout" href="/">home</a>
        &nbsp;·&nbsp;
        <a class="logout" href="/emails">emails</a>
        &nbsp;·&nbsp;
        <a class="logout" href="/docs" target="_blank" rel="noopener">docs</a>
        &nbsp;·&nbsp;
        <a class="logout" href="/logout">log out</a>
      </div>
    </header>
    {% if last_sent %}
      <div style="font-size: 0.8125rem;color:var(--muted);margin:-8px 0 24px;">
        Last sent: <strong>{{ last_sent|e }}</strong>
      </div>
    {% elif recent_issues %}
      <div style="font-size: 0.8125rem;color:var(--warn);margin:-8px 0 24px;">
        Latest issue ({{ recent_issues[0].date|e }}) has not been delivered.
      </div>
    {% else %}
      <div style="font-size: 0.8125rem;color:var(--muted);margin:-8px 0 24px;">
        No issues sent yet.
      </div>
    {% endif %}

    {% if sent %}
      <div style="font-size: 0.8125rem;color:var(--accent);background:var(--panel);border:1px solid var(--accent);border-radius:var(--radius-sm);padding:10px 14px;margin:-8px 0 24px;">
        Digest triggered — your email is on its way.
      </div>
    {% endif %}

    <section>
      <h2>Send now</h2>
      <p style="font-size: 0.8125rem;color:var(--muted);margin:0 0 12px;">
        Trigger a real digest right now. It sends with working rate links, but
        won't appear in recent issues or affect your daily schedule.
      </p>
      <form method="POST" action="/api/send-now">
        <button type="submit" class="primary">Send email now</button>
      </form>
    </section>

    <section>
      <h2>Daily email settings</h2>
      <p style="font-size: 0.8125rem;color:var(--muted);margin:0 0 14px;">
        Article counts control the daily email only — the homepage stays a
        full, rich feed. The theme applies everywhere.
      </p>
      <form method="POST" action="/api/config">
        <div style="display:flex;gap:20px;flex-wrap:wrap;">
          <label style="flex:1;min-width:160px;">
            Max RSS / HN articles
            <input type="number" name="max_rss_articles" min="1" max="40"
                   value="{{ config.max_rss_articles }}"
                   style="display:block;width:100%;margin-top:6px;padding:8px 10px;background:var(--input-bg);color:var(--fg);border:1px solid var(--border);border-radius:var(--radius-sm);font:inherit;">
          </label>
          <label style="flex:1;min-width:160px;">
            Max web-search articles
            <input type="number" name="max_web_articles" min="0" max="30"
                   value="{{ config.max_web_articles }}"
                   style="display:block;width:100%;margin-top:6px;padding:8px 10px;background:var(--input-bg);color:var(--fg);border:1px solid var(--border);border-radius:var(--radius-sm);font:inherit;">
          </label>
        </div>
        <div style="margin-top:18px;">
          <label>
            Web search variety
            <span style="color:var(--muted);font-size: 0.8125rem;">
              — <span id="variety-val">{{ config.web_variety }}</span>/100:
              low stays on your interests, high explores related, ancillary areas
            </span>
            <input type="range" name="web_variety" min="0" max="100" step="5"
                   value="{{ config.web_variety }}"
                   oninput="document.getElementById('variety-val').textContent=this.value"
                   style="display:block;width:100%;margin-top:8px;">
          </label>
          <div style="display:flex;justify-content:space-between;font-size: 0.6875rem;color:var(--muted);">
            <span>on-topic</span><span>exploratory</span>
          </div>
        </div>
        <div style="margin-top:18px;display:flex;gap:20px;flex-wrap:wrap;align-items:flex-end;">
          <label style="flex:1;min-width:200px;display:flex;align-items:center;gap:8px;">
            <input type="checkbox" name="x_enabled" value="true"
                   {% if config.x_enabled %}checked{% endif %}>
            <span>Pull posts from X (Twitter)
              <span style="color:var(--muted);font-size: 0.8125rem;">— needs an xAI API key; matched to your profile</span>
            </span>
          </label>
          <label style="flex:1;min-width:160px;">
            Max X posts
            <input type="number" name="max_x_articles" min="1" max="30"
                   value="{{ config.max_x_articles }}"
                   style="display:block;width:100%;margin-top:6px;padding:8px 10px;background:var(--input-bg);color:var(--fg);border:1px solid var(--border);border-radius:var(--radius-sm);font:inherit;">
          </label>
        </div>
        <div style="margin-top:18px;display:flex;gap:20px;flex-wrap:wrap;align-items:flex-start;">
          <label style="flex:1;min-width:200px;max-width:320px;display:block;">
            Theme
            <span style="color:var(--muted);font-size: 0.8125rem;">— styles the web pages and the daily email</span>
            <select name="theme"
                    style="display:block;width:100%;margin-top:6px;padding:8px 10px;background:var(--input-bg);color:var(--fg);border:1px solid var(--border);border-radius:var(--radius-sm);font:inherit;">
              {% for t in themes %}
              <option value="{{ t.key|e }}"{% if t.key == config.theme %} selected{% endif %}>{{ t.label|e }}</option>
              {% endfor %}
            </select>
          </label>
          <label style="flex:1;min-width:200px;display:block;">
            Text size
            <span style="color:var(--muted);font-size: 0.8125rem;">
              — <span id="textsize-val">{{ config.text_size }}</span>%, on the web pages and in the email
            </span>
            <input type="range" name="text_size" min="75" max="150" step="5"
                   value="{{ config.text_size }}"
                   oninput="document.getElementById('textsize-val').textContent=this.value"
                   style="display:block;width:100%;margin-top:8px;">
            <div style="display:flex;justify-content:space-between;font-size: 0.6875rem;color:var(--muted);">
              <span>smaller</span><span>larger</span>
            </div>
          </label>
        </div>
        <div class="save-row">
          <button type="submit" class="primary">Save settings</button>
        </div>
      </form>
    </section>

    <section>
      <h2>Feeds<span class="count">({{ feeds|length }})</span></h2>

      {% if feeds %}
      <ul class="feeds">
        {% for feed in feeds %}
        <li>
          <div class="feed-info">
            <div class="feed-title">{{ (feed.title or feed.url)|e }}</div>
            <div class="feed-url">{{ feed.url|e }}</div>
            {% if feed.added_at %}<div class="feed-added">added {{ feed.added_at|e }}</div>{% endif %}
          </div>
          <form class="inline" method="POST" action="/api/feeds/delete" onsubmit="return confirm('Delete this feed?');">
            <input type="hidden" name="url" value="{{ feed.url|e }}">
            <button type="submit" class="danger">Delete</button>
          </form>
        </li>
        {% endfor %}
      </ul>
      {% else %}
      <div class="empty">No feeds yet.</div>
      {% endif %}

      <form class="add-form" method="POST" action="/api/feeds">
        <input type="url" name="url" placeholder="https://example.com/rss" required>
        <input type="text" name="title" placeholder="Title (optional)">
        <button type="submit" class="primary">Add</button>
      </form>
    </section>

    <section>
      <h2>Newsletter subscriptions<span class="count">({{ subscriptions|length }})</span></h2>
      <p style="font-size: 0.8125rem;color:var(--muted);margin:0 0 14px;">
        Subscribe to email newsletters as a source. Generate an address, paste it
        into the newsletter's signup form, and daily scoop folds its links into the
        daily ranking. Double opt-in confirmations are followed automatically.
      </p>

      {% if not mail_domain %}
      <div style="font-size: 0.8125rem;color:var(--warn);background:var(--bad-bg);border:1px solid var(--bad-border);border-radius:var(--radius-sm);padding:10px 14px;margin-bottom:14px;">
        No inbound mail domain configured yet. Set <code>MAIL_DOMAIN</code> (and
        point its MX records at SES) to start generating addresses — see the
        README.
      </div>
      {% endif %}

      {% if subscriptions %}
      <ul class="feeds">
        {% for sub in subscriptions %}
        <li>
          <div class="feed-info">
            <div class="feed-title">{{ (sub.source or "(unlabeled)")|e }}</div>
            <div class="feed-url" style="font-family:var(--font-mono);">{{ sub.address|e }}</div>
            <div class="feed-added">
              {% if sub.status == "confirmed" %}
                <span style="color:var(--accent);">✓ confirmed</span>
              {% else %}
                <span style="color:var(--warn);">⏳ pending confirmation</span>
              {% endif %}
              · added {{ sub.created_at|e }}{% if sub.last_received_at %} · last mail {{ sub.last_received_at|e }}{% endif %}
            </div>
          </div>
          <form class="inline" method="POST" action="/api/subscriptions/delete" onsubmit="return confirm('Delete this subscription? You will stop receiving its newsletter links.');">
            <input type="hidden" name="address" value="{{ sub.address|e }}">
            <button type="submit" class="danger">Delete</button>
          </form>
        </li>
        {% endfor %}
      </ul>
      {% else %}
      <div class="empty">No newsletter subscriptions yet.</div>
      {% endif %}

      <form class="add-form" method="POST" action="/api/subscriptions">
        <input type="text" name="source" placeholder="Newsletter name (e.g. Stratechery)"{% if not mail_domain %} disabled{% endif %}>
        <button type="submit" class="primary"{% if not mail_domain %} disabled{% endif %}>Generate address</button>
      </form>
    </section>

    <section>
      <h2>Profile</h2>
      <form method="POST" action="/api/profile">
        <textarea name="markdown" rows="12" placeholder="Tell daily scoop about your interests in plain text or Markdown.">{{ profile_md|e }}</textarea>
        <div class="save-row">
          <button type="submit" class="primary">Save</button>
        </div>
      </form>
    </section>
  </div>
</body>
</html>
