<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>newslet</title>
<style>
  :root {
    --bg: #f6f6f4; --panel: #ffffff; --fg: #1a1a1a; --muted: #777;
    --border: #e6e6e1; --accent: #0b3d91; --accent-bg: #eef2fb;
    --ok: #1a7a3a; --ok-bg: #eef7ef; --ok-border: #d4e8d8;
    --bad: #9a2a2a; --bad-bg: #fbeeee; --bad-border: #e8d4d4;
    --hn: #ff6600; --chip: #f0f0ec;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #15151a; --panel: #1d1d22; --fg: #ececec; --muted: #9a9aa3;
      --border: #2c2c33; --accent: #8ab4ff; --accent-bg: #1b2436;
      --ok: #6dc28a; --ok-bg: #16271b; --ok-border: #244a30;
      --bad: #ff8a8a; --bad-bg: #2a1c1c; --bad-border: #4a2a2a;
      --hn: #ff8c42; --chip: #26262d;
    }
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; background: var(--bg); color: var(--fg); }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; line-height: 1.5; -webkit-font-smoothing: antialiased; }
  a { color: var(--accent); }
  .wrap { max-width: 820px; margin: 0 auto; padding: 0 16px 80px; }

  header.top {
    position: sticky; top: 0; z-index: 20; background: var(--bg);
    border-bottom: 1px solid var(--border);
    display: flex; align-items: center; justify-content: space-between;
    gap: 12px; padding: 14px 0; flex-wrap: wrap;
  }
  .brand { font-family: Georgia, 'Times New Roman', serif; font-size: 22px; font-weight: 700; letter-spacing: -0.01em; }
  .topright { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
  .navlinks { font-size: 13px; }
  .navlinks a { color: var(--muted); text-decoration: none; margin-left: 14px; }
  .navlinks a:hover { color: var(--fg); text-decoration: underline; }

  .lede { margin: 22px 0 8px; }
  .lede h1 { font-family: Georgia, serif; font-size: 24px; line-height: 1.25; margin: 0 0 8px; }
  .lede p { color: var(--fg); margin: 0; font-size: 16px; }
  .count { color: var(--muted); font-size: 13px; }
  .updated { color: var(--muted); font-size: 12px; }

  .btn { font: inherit; cursor: pointer; padding: 8px 14px; border-radius: 8px;
    border: 1px solid var(--accent); background: var(--accent); color: #fff; font-weight: 600; }
  .btn.secondary { background: var(--panel); color: var(--accent); }
  .btn:disabled { opacity: .6; cursor: progress; }

  /* Research / "textbook" box */
  .research { background: var(--panel); border: 1px solid var(--border); border-radius: 10px; padding: 16px; margin: 20px 0; }
  .research label { font-weight: 600; display: block; margin-bottom: 8px; }
  .research .hint { color: var(--muted); font-weight: 400; font-size: 13px; }
  .research form { display: flex; gap: 8px; flex-wrap: wrap; }
  .research input[type=text] {
    flex: 1; min-width: 220px; padding: 10px 12px; font: inherit;
    background: var(--bg); color: var(--fg); border: 1px solid var(--border); border-radius: 8px;
  }

  h2.section { font-size: 13px; text-transform: uppercase; letter-spacing: .06em; color: var(--muted);
    margin: 30px 0 10px; padding-bottom: 6px; border-bottom: 1px solid var(--border); }

  .grid { display: grid; gap: 12px; }
  .card { background: var(--panel); border: 1px solid var(--border); border-radius: 10px; padding: 16px 16px 12px; }
  .card.voted-up { border-color: var(--ok-border); box-shadow: inset 3px 0 0 var(--ok); }
  .card.voted-down { opacity: .62; box-shadow: inset 3px 0 0 var(--bad); }
  .card h3 { font-size: 17px; line-height: 1.35; margin: 0 0 6px; }
  .card h3 a { color: var(--fg); text-decoration: none; }
  .card h3 a:hover { color: var(--accent); text-decoration: underline; }
  .meta { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; font-size: 12px; color: var(--muted); margin-bottom: 8px; }
  .src { font-weight: 600; }
  .src.hn { color: var(--hn); }
  .badge { background: var(--chip); border-radius: 999px; padding: 1px 8px; }
  .meta a { color: var(--muted); text-decoration: none; }
  .meta a:hover { text-decoration: underline; color: var(--fg); }
  .blurb { font-size: 15px; color: var(--fg); margin: 0 0 10px; }
  .blurb:empty { display: none; }

  .actions { display: flex; gap: 8px; }
  .vote { font: inherit; cursor: pointer; padding: 6px 14px; border-radius: 8px; font-family: ui-monospace, Menlo, Consolas, monospace; font-size: 16px; line-height: 1; }
  .vote.up { color: var(--ok); background: var(--ok-bg); border: 1px solid var(--ok-border); }
  .vote.down { color: var(--bad); background: var(--bad-bg); border: 1px solid var(--bad-border); }
  .vote[aria-pressed="true"] { outline: 2px solid currentColor; outline-offset: 1px; }
  .vote:disabled { cursor: progress; opacity: .6; }

  .empty { color: var(--muted); padding: 10px 0; }
  .banner { background: var(--accent-bg); border: 1px solid var(--border); border-radius: 10px; padding: 16px; margin: 20px 0; }
  .spinner { display: none; color: var(--muted); font-size: 14px; padding: 8px 0; }
  .kbd-help { color: var(--muted); font-size: 12px; margin-top: 28px; text-align: center; }
  .kbd { background: var(--chip); border: 1px solid var(--border); border-radius: 4px; padding: 0 5px; font-family: ui-monospace, monospace; }
</style>
</head>
<body>
{# ---- card macro: one article, with sticky vote state (defined before use) ---- #}
{% macro card(c) %}
<article class="card{% if c.rating == 'up' %} voted-up{% elif c.rating == 'down' %} voted-down{% endif %}"
         data-source="{{ c.source|e }}" data-url="{{ c.url|e }}" tabindex="0">
  <h3><a href="{{ c.url|e }}" target="_blank" rel="noopener noreferrer">{{ c.title|e }}</a></h3>
  <div class="meta">
    {% if c.source %}<span class="src{% if c.source == 'Hacker News' %} hn{% endif %}">{{ c.source|e }}</span>{% endif %}
    {% if c.points is not none %}<span class="badge">▲ {{ c.points }}</span>{% endif %}
    {% if c.comments is not none %}<span class="badge">💬 {{ c.comments }}</span>{% endif %}
    {% if c.comments_url %}<a href="{{ c.comments_url|e }}" target="_blank" rel="noopener noreferrer">discussion ↗</a>{% endif %}
  </div>
  {% if c.blurb %}<p class="blurb">{{ c.blurb|e }}</p>{% endif %}
  <form class="actions" method="post" action="/api/vote">
    <input type="hidden" name="url" value="{{ c.url|e }}">
    <input type="hidden" name="title" value="{{ c.title|e }}">
    <input type="hidden" name="date" value="{{ vote_key|e }}">
    <button class="vote up" type="submit" name="rating" value="up" aria-pressed="{{ 'true' if c.rating == 'up' else 'false' }}" aria-label="Upvote">+</button>
    <button class="vote down" type="submit" name="rating" value="down" aria-pressed="{{ 'true' if c.rating == 'down' else 'false' }}" aria-label="Downvote">&minus;</button>
  </form>
</article>
{% endmacro %}
<div class="wrap">
  <header class="top">
    <div class="brand">newslet</div>
    <div class="topright">
      <button class="btn" id="refresh-btn" data-created="{{ created_iso|e }}">↻ Refresh</button>
      <nav class="navlinks">
        <a href="/admin">admin</a>
        <a href="/issues">issues</a>
      </nav>
    </div>
  </header>

  <div class="lede">
    {% if subject %}<h1>{{ subject|e }}</h1>{% endif %}
    {% if intro %}<p>{{ intro|e }}</p>{% endif %}
    {% if has_content %}
    <p class="count">{{ total }} articles · {{ picks|length }} ranked · {{ web_articles|length }} from around the web. Your <span style="color:var(--ok)">+</span>/<span style="color:var(--bad)">−</span> votes tune future ranking. <span class="updated">Updated {{ created_label|e }}.</span></p>
    {% endif %}
  </div>

  <div class="spinner" id="refresh-spinner">Refreshing your homepage — this takes about a minute…</div>

  <!-- Research desk: type a subject, the web search hones in -->
  <section class="research">
    <label for="q">Research a subject <span class="hint">— type a topic and pull a fresh reading list from the open web</span></label>
    <form id="search-form" method="get" action="">
      <input type="text" id="q" name="q" placeholder="e.g. retrieval-augmented generation, ocean carbon capture…" value="{{ query|e }}" autocomplete="off">
      <button class="btn" type="submit" id="search-btn">Search</button>
    </form>
    <div class="spinner" id="search-spinner">Searching the web…</div>
    <div class="grid" id="search-results" style="margin-top:12px;">
      {% if query %}
        {% if search_results %}
          <h2 class="section" style="margin-top:14px;">Results for "{{ query|e }}"</h2>
          {% for c in search_results %}{{ card(c) }}{% endfor %}
        {% else %}
          <div class="empty">No results for "{{ query|e }}" — try a broader subject.</div>
        {% endif %}
      {% endif %}
    </div>
  </section>

  {% if not has_content %}
  <div class="banner">
    <strong>Your homepage hasn't been generated yet.</strong>
    <p style="margin:8px 0 0;color:var(--muted);">Hit <em>Refresh</em> to pull together ranked picks from your feeds and Hacker News, plus a block from around the open web. It takes about a minute.</p>
  </div>
  {% endif %}

  {% if picks %}
  <h2 class="section">Ranked picks</h2>
  <div class="grid" id="picks-grid">
    {% for c in picks %}{{ card(c) }}{% endfor %}
  </div>
  {% endif %}

  {% if web_articles %}
  <h2 class="section">From around the web</h2>
  <div class="grid" id="web-grid">
    {% for c in web_articles %}{{ card(c) }}{% endfor %}
  </div>
  {% endif %}

  <p class="kbd-help">Shortcuts: <span class="kbd">j</span>/<span class="kbd">k</span> move · <span class="kbd">u</span> upvote · <span class="kbd">d</span> downvote · <span class="kbd">o</span> open · <span class="kbd">r</span> refresh</p>
</div>

<script>
(function () {
  "use strict";

  // ---- Voting: intercept the form post, fetch JSON, update sticky state ----
  function wireVotes(root) {
    root.querySelectorAll("form.actions").forEach(function (form) {
      form.addEventListener("submit", function (ev) {
        ev.preventDefault();
        var btn = ev.submitter || document.activeElement;
        var rating = btn && btn.value === "down" ? "down" : "up";
        castVote(form, rating);
      });
    });
  }

  function castVote(form, rating) {
    var card = form.closest(".card");
    var ups = form.querySelector(".vote.up");
    var downs = form.querySelector(".vote.down");
    ups.disabled = downs.disabled = true;
    var body = new URLSearchParams(new FormData(form));
    body.set("rating", rating);
    fetch("/api/vote", {
      method: "POST",
      headers: { "Accept": "application/json", "Content-Type": "application/x-www-form-urlencoded" },
      body: body.toString()
    }).then(function (r) {
      if (!r.ok) throw new Error("vote failed");
      return r.json();
    }).then(function () {
      card.classList.toggle("voted-up", rating === "up");
      card.classList.toggle("voted-down", rating === "down");
      ups.setAttribute("aria-pressed", rating === "up" ? "true" : "false");
      downs.setAttribute("aria-pressed", rating === "down" ? "true" : "false");
    }).catch(function () {
      form.submit(); // fall back to a full form post so the vote still lands
    }).finally(function () {
      ups.disabled = downs.disabled = false;
    });
  }

  // ---- Refresh: async regenerate the homepage, poll, then reload ----
  var refreshBtn = document.getElementById("refresh-btn");
  function startRefresh() {
    var spinner = document.getElementById("refresh-spinner");
    var baseline = refreshBtn.getAttribute("data-created") || "";
    refreshBtn.disabled = true;
    spinner.style.display = "block";
    fetch("/api/home/refresh", { method: "POST", headers: { "Accept": "application/json" } })
      .then(function (r) { if (!r.ok) throw new Error("refresh failed"); return r.json(); })
      .then(function () { pollStatus(baseline, 0); })
      .catch(function () {
        spinner.textContent = "Couldn't start a refresh — try again in a moment.";
        refreshBtn.disabled = false;
      });
  }
  function pollStatus(baseline, tries) {
    if (tries > 40) { // ~3.5 min ceiling
      document.getElementById("refresh-spinner").textContent =
        "Still working… reload the page in a minute.";
      refreshBtn.disabled = false;
      return;
    }
    setTimeout(function () {
      fetch("/api/home/status", { headers: { "Accept": "application/json" } })
        .then(function (r) { return r.json(); })
        .then(function (d) {
          if (d.ready && d.created_at && d.created_at !== baseline) {
            window.location.reload();
          } else {
            pollStatus(baseline, tries + 1);
          }
        })
        .catch(function () { pollStatus(baseline, tries + 1); });
    }, 5000);
  }
  if (refreshBtn) refreshBtn.addEventListener("click", startRefresh);

  // ---- Research box: inline search via JSON, no full reload ----
  var sform = document.getElementById("search-form");
  if (sform) {
    sform.addEventListener("submit", function (ev) {
      var q = document.getElementById("q").value.trim();
      if (!q) return;
      ev.preventDefault();
      var spinner = document.getElementById("search-spinner");
      var out = document.getElementById("search-results");
      var btn = document.getElementById("search-btn");
      spinner.style.display = "block";
      out.innerHTML = "";
      btn.disabled = true;
      fetch("/api/search?q=" + encodeURIComponent(q), { headers: { "Accept": "application/json" } })
        .then(function (r) { return r.json(); })
        .then(function (data) { renderResults(out, data.results || [], q); })
        .catch(function () { window.location.search = "?q=" + encodeURIComponent(q); })
        .finally(function () { spinner.style.display = "none"; btn.disabled = false; });
    });
  }

  function esc(s) {
    var d = document.createElement("div"); d.textContent = s == null ? "" : s; return d.innerHTML;
  }

  function renderResults(out, results, q) {
    if (!results.length) {
      out.innerHTML = '<div class="empty">No results for "' + esc(q) + '" — try a broader subject.</div>';
      return;
    }
    var date = document.querySelector('input[name="date"]');
    date = date ? date.value : "home";
    var html = '<h2 class="section" style="margin-top:14px;">Results for "' + esc(q) + '"</h2>';
    results.forEach(function (c) {
      var badges = "";
      if (c.points != null) badges += '<span class="badge">▲ ' + esc(c.points) + "</span>";
      if (c.comments != null) badges += '<span class="badge">💬 ' + esc(c.comments) + "</span>";
      if (c.comments_url) badges += '<a href="' + esc(c.comments_url) + '" target="_blank" rel="noopener noreferrer">discussion ↗</a>';
      var srcCls = c.source === "Hacker News" ? "src hn" : "src";
      html +=
        '<article class="card" data-source="' + esc(c.source) + '" data-url="' + esc(c.url) + '" tabindex="0">' +
          '<h3><a href="' + esc(c.url) + '" target="_blank" rel="noopener noreferrer">' + esc(c.title) + "</a></h3>" +
          '<div class="meta">' + (c.source ? '<span class="' + srcCls + '">' + esc(c.source) + "</span>" : "") + badges + "</div>" +
          (c.blurb ? '<p class="blurb">' + esc(c.blurb) + "</p>" : "") +
          '<form class="actions" method="post" action="/api/vote">' +
            '<input type="hidden" name="url" value="' + esc(c.url) + '">' +
            '<input type="hidden" name="title" value="' + esc(c.title) + '">' +
            '<input type="hidden" name="date" value="' + esc(date) + '">' +
            '<button class="vote up" type="submit" name="rating" value="up" aria-pressed="false" aria-label="Upvote">+</button>' +
            '<button class="vote down" type="submit" name="rating" value="down" aria-pressed="false" aria-label="Downvote">−</button>' +
          "</form>" +
        "</article>";
    });
    out.innerHTML = html;
    wireVotes(out);
  }

  // ---- Keyboard navigation ----
  var cur = -1;
  function cards() {
    return Array.prototype.slice.call(document.querySelectorAll(".card"));
  }
  function focusCard(i) {
    var cs = cards();
    if (!cs.length) return;
    cur = Math.max(0, Math.min(i, cs.length - 1));
    cs[cur].focus();
    cs[cur].scrollIntoView({ block: "center", behavior: "smooth" });
  }
  document.addEventListener("keydown", function (ev) {
    var tag = (ev.target.tagName || "").toLowerCase();
    if (tag === "input" || tag === "textarea") return;
    if (ev.key === "j") { ev.preventDefault(); focusCard(cur + 1); }
    else if (ev.key === "k") { ev.preventDefault(); focusCard(cur - 1); }
    else if (ev.key === "r") { ev.preventDefault(); if (refreshBtn && !refreshBtn.disabled) startRefresh(); }
    else if (ev.key === "u" || ev.key === "d") {
      var card = cards()[cur];
      if (card) { var f = card.querySelector("form.actions"); if (f) castVote(f, ev.key === "u" ? "up" : "down"); }
    } else if (ev.key === "o") {
      var c2 = cards()[cur];
      if (c2) { var a = c2.querySelector("h3 a"); if (a) window.open(a.href, "_blank", "noopener"); }
    }
  });

  wireVotes(document);

  // First visit with no content yet: kick off generation automatically.
  if (refreshBtn && !{{ 'true' if has_content else 'false' }}) startRefresh();
})();
</script>
</body>
</html>
