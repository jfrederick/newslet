<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>daily scoop</title>
<style>
  {{ theme_css }}
  * { box-sizing: border-box; }
  html, body { margin: 0; background: var(--bg); color: var(--fg); }
  body { font-family: var(--font-body); line-height: 1.5; -webkit-font-smoothing: antialiased; }
  a { color: var(--accent); }
  .wrap { max-width: 820px; margin: 0 auto; padding: 0 16px 80px; }

  header.top {
    background: var(--bg); border-bottom: 1px solid var(--border);
    display: flex; align-items: center; justify-content: space-between;
    gap: 12px; padding: 14px 0; flex-wrap: wrap;
  }
  .brand { font-family: var(--font-brand); font-size: 1.375rem; font-weight: 700; letter-spacing: -0.01em; }
  .navlinks { font-size: 0.8125rem; }
  .navlinks a { color: var(--muted); text-decoration: none; margin-left: 14px; }
  .navlinks a:hover { color: var(--fg); text-decoration: underline; }

  .lede { margin: 26px 0 8px; }
  .dateline { font-size: 0.8125rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: .08em; color: var(--muted); margin: 0 0 6px; }
  .lede h1 { font-family: var(--font-brand); font-size: 1.625rem; line-height: 1.22; margin: 0 0 8px; }
  .lede p { color: var(--fg); margin: 0; font-size: 1rem; }
  .count { color: var(--muted); font-size: 0.8125rem; }

  .btn { font: inherit; cursor: pointer; padding: 8px 14px; border-radius: var(--radius-sm);
    border: 1px solid var(--accent); background: var(--accent); color: var(--accent-fg); font-weight: 600; }
  .btn:disabled { opacity: .6; cursor: progress; }

  /* Research / "textbook" box */
  .research { background: var(--panel); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px; margin: 20px 0; }
  .research label { font-weight: 600; display: block; margin-bottom: 8px; }
  .research .hint { color: var(--muted); font-weight: 400; font-size: 0.8125rem; }
  .research form { display: flex; gap: 8px; flex-wrap: wrap; }
  .research input[type=text] {
    flex: 1; min-width: 220px; padding: 10px 12px; font: inherit;
    background: var(--input-bg); color: var(--fg); border: 1px solid var(--border); border-radius: var(--radius-sm);
  }

  h2.section { font-size: 0.8125rem; text-transform: uppercase; letter-spacing: .06em; color: var(--muted);
    margin: 30px 0 10px; padding-bottom: 6px; border-bottom: 1px solid var(--border); }

  .grid { display: grid; gap: 12px; }
  .card { background: var(--panel); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px 16px 12px;
    transition: opacity .3s ease, transform .3s ease, max-height .35s ease, padding .35s ease, margin .35s ease;
    max-height: 1200px; }
  .card.voted-up { border-color: var(--ok-border); box-shadow: inset 3px 0 0 var(--ok); }
  .card.removing { opacity: 0; max-height: 0; padding-top: 0; padding-bottom: 0;
    margin-top: 0; margin-bottom: 0; transform: translateX(-14px); overflow: hidden; }
  .card h3 { font-size: 1.0625rem; line-height: 1.35; margin: 0 0 6px; }
  .card h3 a { color: var(--fg); text-decoration: none; }
  .card h3 a:hover { color: var(--accent); text-decoration: underline; }
  .meta { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; font-size: 0.75rem; color: var(--muted); margin-bottom: 8px; }
  .src { font-weight: 600; }
  .src.hn { color: var(--hn); }
  .badge { background: var(--chip); border-radius: 999px; padding: 1px 8px; }
  .meta a { color: var(--muted); text-decoration: none; }
  .meta a:hover { text-decoration: underline; color: var(--fg); }
  .blurb { font-size: 0.9375rem; color: var(--fg); margin: 0 0 10px; }
  .blurb:empty { display: none; }

  .actions { display: flex; gap: 8px; }
  .vote { font: inherit; cursor: pointer; padding: 6px 14px; border-radius: var(--radius-sm); font-family: var(--font-mono); font-size: 1rem; line-height: 1; }
  .vote.up { color: var(--ok); background: var(--ok-bg); border: 1px solid var(--ok-border); }
  .vote.down { color: var(--bad); background: var(--bad-bg); border: 1px solid var(--bad-border); }
  .vote[aria-pressed="true"] { outline: 2px solid currentColor; outline-offset: 1px; }
  .vote:disabled { cursor: progress; opacity: .6; }

  .empty { color: var(--muted); padding: 10px 0; }
  .banner { background: var(--accent-bg); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px; margin: 20px 0; }
  .spinner { display: none; color: var(--muted); font-size: 0.875rem; padding: 8px 0; }
  .stale-note { color: var(--muted); font-size: 0.875rem; padding: 8px 0; font-style: italic; }
</style>
</head>
<body>
{# ---- card macro: one article, with sticky vote state (defined before use) ---- #}
{% macro card(c) %}
<article class="card{% if c.rating == 'up' %} voted-up{% endif %}"
         data-source="{{ c.source|e }}" data-url="{{ c.url|e }}">
  <h3><a href="{{ c.url|e }}" target="_blank" rel="noopener noreferrer">{{ c.title|e }}</a></h3>
  <div class="meta">
    {% if c.source %}<span class="src{% if c.source == 'Hacker News' %} hn{% endif %}">{{ c.source|e }}</span>{% endif %}
    {% if c.points is not none %}<span class="badge">▲ {{ c.points }}</span>{% endif %}
    {% if c.comments is not none %}<span class="badge">💬 {{ c.comments }}</span>{% endif %}
    {% if c.comments_url %}<a href="{{ c.comments_url|e }}" target="_blank" rel="noopener noreferrer">discussion ↗</a>{% endif %}
  </div>
  {% if c.blurb %}<p class="blurb">{{ c.blurb|e }}</p>{% endif %}
  <form class="actions" method="post" action="/api/vote">
    <input type="hidden" name="url" value="{{ c.url|e }}">
    <input type="hidden" name="title" value="{{ c.title|e }}">
    <input type="hidden" name="date" value="{{ vote_key|e }}">
    <button class="vote up" type="submit" name="rating" value="up" aria-pressed="{{ 'true' if c.rating == 'up' else 'false' }}" aria-label="Upvote">+</button>
    <button class="vote down" type="submit" name="rating" value="down" aria-pressed="false" aria-label="Downvote (remove)">&minus;</button>
  </form>
</article>
{% endmacro %}
<div class="wrap">
  <header class="top">
    <div class="brand">daily scoop</div>
    <nav class="navlinks">
      <a href="/admin">admin</a>
      <a href="/emails">emails</a>
    </nav>
  </header>

  <div class="lede">
    <div class="dateline">{{ date_header|e }}</div>
    {% if subject %}<h1>{{ subject|e }}</h1>{% endif %}
    {% if intro %}<p>{{ intro|e }}</p>{% endif %}
  </div>

  {% if stale %}
  <div class="stale-note" id="stale-note">
    {% if has_content %}
    Showing {{ stale_day|e }}'s edition — today's update hasn't run yet.
    {% else %}
    No edition yet — the daily update builds one each morning.
    {% endif %}
  </div>
  {% endif %}

  {% if picks %}
  <h2 class="section">Ranked picks</h2>
  <div class="grid" id="picks-grid">
    {% for c in picks %}{{ card(c) }}{% endfor %}
  </div>
  {% endif %}

  {% if web_articles %}
  <h2 class="section">From around the web</h2>
  <div class="grid" id="web-grid">
    {% for c in web_articles %}{{ card(c) }}{% endfor %}
  </div>
  {% endif %}

  <!-- Research desk: type a subject, the web search hones in -->
  <section class="research">
    <label for="q">Research a subject <span class="hint">— type a topic and pull a fresh reading list from the open web</span></label>
    <form id="search-form" method="get" action="">
      <input type="text" id="q" name="q" placeholder="e.g. retrieval-augmented generation, ocean carbon capture…" value="{{ query|e }}" autocomplete="off">
      <button class="btn" type="submit" id="search-btn">Search</button>
    </form>
    <div class="spinner" id="search-spinner">Searching the web…</div>
    <div class="grid" id="search-results" style="margin-top:12px;">
      {% if query %}
        {% if search_results %}
          <h2 class="section" style="margin-top:14px;">Results for "{{ query|e }}"</h2>
          {% for c in search_results %}{{ card(c) }}{% endfor %}
        {% else %}
          <div class="empty">No results for "{{ query|e }}" — try a broader subject.</div>
        {% endif %}
      {% endif %}
    </div>
  </section>
</div>

<script>
(function () {
  "use strict";

  // ---- Voting: intercept the form post, fetch JSON, update the page ----
  function wireVotes(root) {
    root.querySelectorAll("form.actions").forEach(function (form) {
      form.addEventListener("submit", function (ev) {
        ev.preventDefault();
        var btn = ev.submitter || document.activeElement;
        var rating = btn && btn.value === "down" ? "down" : "up";
        castVote(form, rating);
      });
    });
  }

  function removeCard(card) {
    if (!card) return;
    card.classList.add("removing");
    var done = false;
    function gone() { if (done) return; done = true; card.remove(); }
    card.addEventListener("transitionend", gone, { once: true });
    setTimeout(gone, 600); // fallback if transitionend doesn't fire
  }

  function castVote(form, rating) {
    var card = form.closest(".card");
    var ups = form.querySelector(".vote.up");
    var downs = form.querySelector(".vote.down");
    ups.disabled = downs.disabled = true;
    var body = new URLSearchParams(new FormData(form));
    body.set("rating", rating);
    fetch("/api/vote", {
      method: "POST",
      headers: { "Accept": "application/json", "Content-Type": "application/x-www-form-urlencoded" },
      body: body.toString()
    }).then(function (r) {
      if (!r.ok) throw new Error("vote failed");
      return r.json();
    }).then(function () {
      if (rating === "down") {
        removeCard(card); // a downvote makes the article gracefully disappear
      } else {
        card.classList.add("voted-up");
        ups.setAttribute("aria-pressed", "true");
        ups.disabled = downs.disabled = false;
      }
    }).catch(function () {
      ups.disabled = downs.disabled = false;
      form.submit(); // fall back to a full form post so the vote still lands
    });
  }

  // ---- Research box: inline search via JSON, no full reload ----
  var sform = document.getElementById("search-form");
  if (sform) {
    sform.addEventListener("submit", function (ev) {
      var q = document.getElementById("q").value.trim();
      if (!q) return;
      ev.preventDefault();
      var spinner = document.getElementById("search-spinner");
      var out = document.getElementById("search-results");
      var btn = document.getElementById("search-btn");
      spinner.style.display = "block";
      out.innerHTML = "";
      btn.disabled = true;
      fetch("/api/search?q=" + encodeURIComponent(q), { headers: { "Accept": "application/json" } })
        .then(function (r) { return r.json(); })
        .then(function (data) { renderResults(out, data.results || [], q); })
        .catch(function () { window.location.search = "?q=" + encodeURIComponent(q); })
        .finally(function () { spinner.style.display = "none"; btn.disabled = false; });
    });
  }

  function esc(s) {
    var d = document.createElement("div"); d.textContent = s == null ? "" : s; return d.innerHTML;
  }

  function renderResults(out, results, q) {
    if (!results.length) {
      out.innerHTML = '<div class="empty">No results for "' + esc(q) + '" — try a broader subject.</div>';
      return;
    }
    var date = document.querySelector('input[name="date"]');
    date = date ? date.value : "home";
    var html = '<h2 class="section" style="margin-top:14px;">Results for "' + esc(q) + '"</h2>';
    results.forEach(function (c) {
      var badges = "";
      if (c.points != null) badges += '<span class="badge">▲ ' + esc(c.points) + "</span>";
      if (c.comments != null) badges += '<span class="badge">💬 ' + esc(c.comments) + "</span>";
      if (c.comments_url) badges += '<a href="' + esc(c.comments_url) + '" target="_blank" rel="noopener noreferrer">discussion ↗</a>';
      var srcCls = c.source === "Hacker News" ? "src hn" : "src";
      html +=
        '<article class="card" data-source="' + esc(c.source) + '" data-url="' + esc(c.url) + '">' +
          '<h3><a href="' + esc(c.url) + '" target="_blank" rel="noopener noreferrer">' + esc(c.title) + "</a></h3>" +
          '<div class="meta">' + (c.source ? '<span class="' + srcCls + '">' + esc(c.source) + "</span>" : "") + badges + "</div>" +
          (c.blurb ? '<p class="blurb">' + esc(c.blurb) + "</p>" : "") +
          '<form class="actions" method="post" action="/api/vote">' +
            '<input type="hidden" name="url" value="' + esc(c.url) + '">' +
            '<input type="hidden" name="title" value="' + esc(c.title) + '">' +
            '<input type="hidden" name="date" value="' + esc(date) + '">' +
            '<button class="vote up" type="submit" name="rating" value="up" aria-pressed="false" aria-label="Upvote">+</button>' +
            '<button class="vote down" type="submit" name="rating" value="down" aria-pressed="false" aria-label="Downvote (remove)">−</button>' +
          "</form>" +
        "</article>";
    });
    out.innerHTML = html;
    wireVotes(out);
  }

  wireVotes(document);
})();
</script>
</body>
</html>
