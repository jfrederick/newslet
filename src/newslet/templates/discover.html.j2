<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>daily scoop · discover</title>
<style>
  {{ theme_css }}
  * { box-sizing: border-box; }
  html, body { margin: 0; background: var(--bg); color: var(--fg); }
  body { font-family: var(--font-body); line-height: 1.5; -webkit-font-smoothing: antialiased; }
  a { color: var(--accent); }
  .wrap { max-width: 820px; margin: 0 auto; padding: 0 16px 80px; }

  header.top {
    background: var(--bg); border-bottom: 1px solid var(--border);
    display: flex; align-items: center; justify-content: space-between;
    gap: 12px; padding: 14px 0; flex-wrap: wrap;
  }
  .brand { font-family: var(--font-brand); font-size: 1.375rem; font-weight: 700; letter-spacing: -0.01em; }
  .navlinks { font-size: 0.8125rem; }
  .navlinks a { color: var(--muted); text-decoration: none; margin-left: 14px; }
  .navlinks a:hover { color: var(--fg); text-decoration: underline; }

  .lede { margin: 26px 0 8px; }
  .dateline { font-size: 0.8125rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: .08em; color: var(--muted); margin: 0 0 6px; }
  .lede h1 { font-family: var(--font-brand); font-size: 1.625rem; line-height: 1.22; margin: 0 0 8px; }
  .lede p { color: var(--muted); margin: 0; font-size: 0.9375rem; }

  .btn { font: inherit; cursor: pointer; padding: 8px 14px; border-radius: var(--radius-sm);
    border: 1px solid var(--accent); background: var(--accent); color: var(--accent-fg); font-weight: 600; }
  .btn:disabled { opacity: .6; cursor: progress; }

  .notice { background: var(--bad-bg); border: 1px solid var(--bad-border); color: var(--fg);
    border-radius: var(--radius); padding: 14px 16px; margin: 18px 0; font-size: 0.875rem; }
  .notice code { font-family: var(--font-mono); }

  .grid { display: grid; gap: 12px; margin-top: 14px; }
  .card { background: var(--panel); border: 1px solid var(--border); border-radius: var(--radius);
    padding: 16px;
    transition: opacity .3s ease, transform .3s ease, max-height .35s ease, padding .35s ease, margin .35s ease;
    max-height: 1600px; }
  .card.removing { opacity: 0; max-height: 0; padding-top: 0; padding-bottom: 0;
    margin-top: 0; margin-bottom: 0; transform: translateX(-14px); overflow: hidden; }
  .acct-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; }
  .acct-id { min-width: 0; }
  .acct-name { font-size: 1.0625rem; font-weight: 700; line-height: 1.25; }
  .acct-handle { font-family: var(--font-mono); font-size: 0.8125rem; color: var(--muted); text-decoration: none; }
  .acct-handle:hover { color: var(--accent); text-decoration: underline; }
  .bio { font-size: 0.9375rem; margin: 8px 0 0; }
  .reason { font-size: 0.8125rem; color: var(--muted); font-style: italic; margin: 6px 0 0; }
  .posts { list-style: none; padding: 0; margin: 12px 0 0; display: grid; gap: 8px; }
  .posts li { border-left: 2px solid var(--border); padding: 4px 0 4px 10px; }
  .post-text { font-size: 0.875rem; margin: 0; }
  .post-meta { display: flex; gap: 10px; flex-wrap: wrap; align-items: center;
    font-size: 0.6875rem; color: var(--muted); margin-top: 4px; }
  .post-meta a { color: var(--muted); text-decoration: none; }
  .post-meta a:hover { color: var(--fg); text-decoration: underline; }
  .badge { background: var(--chip); border-radius: 999px; padding: 1px 8px; }

  .follow { font: inherit; cursor: pointer; padding: 6px 14px; border-radius: var(--radius-sm); white-space: nowrap;
    color: var(--accent-fg); background: var(--accent); border: 1px solid var(--accent); font-weight: 600; }
  .follow:disabled { opacity: .6; cursor: progress; }

  .empty { color: var(--muted); padding: 10px 0; }
  .spinner { display: none; color: var(--muted); font-size: 0.875rem; padding: 8px 0; }
  .pager { margin: 24px 0 0; text-align: center; }
  #next-btn { display: none; }
  .pager .hint { display: block; color: var(--muted); font-size: 0.75rem; margin-top: 6px; }
</style>
</head>
<body>
<div class="wrap">
  <header class="top">
    <div class="brand">daily scoop · discover</div>
    <nav class="navlinks">
      <a href="/">home</a>
      <a href="/admin">admin</a>
      <a href="/emails">emails</a>
    </nav>
  </header>

  <div class="lede">
    <div class="dateline">Discover · X / Twitter</div>
    <h1>Accounts you might want to follow</h1>
    <p>Profile-matched accounts active in the last 14 days that you don't already
      follow{% if follow_count %} — {{ follow_count }} followed so far{% endif %}.</p>
  </div>

  {% if not x_configured %}
  <div class="notice">
    X discovery needs an xAI API key. Set <code>XAI_API_KEY</code> (the same key
    the X ranking source uses) to start finding accounts.
  </div>
  {% endif %}

  <div class="spinner" id="prep-spinner">Finding accounts — this takes about a minute…</div>

  <div class="grid" id="accounts-grid">
    {% for a in accounts %}
    <article class="card" data-handle="{{ a.handle|e }}">
      <div class="acct-head">
        <div class="acct-id">
          <div class="acct-name">{{ (a.name or a.handle)|e }}</div>
          <a class="acct-handle" href="{{ a.url|e }}" target="_blank" rel="noopener noreferrer">@{{ a.handle|e }}</a>
        </div>
        <form class="follow-form" method="post" action="/api/x/follow">
          <input type="hidden" name="handle" value="{{ a.handle|e }}">
          <input type="hidden" name="name" value="{{ a.name|e }}">
          <button class="follow" type="submit">Follow</button>
        </form>
      </div>
      {% if a.bio %}<p class="bio">{{ a.bio|e }}</p>{% endif %}
      {% if a.reason %}<p class="reason">{{ a.reason|e }}</p>{% endif %}
      {% if a.posts %}
      <ul class="posts">
        {% for p in a.posts %}
        <li>
          <p class="post-text">{{ p.text|e }}</p>
          <div class="post-meta">
            <a href="{{ p.url|e }}" target="_blank" rel="noopener noreferrer">view post ↗</a>
            {% if p.posted_at %}<span>{{ p.posted_at.strftime('%b %d') }}</span>{% endif %}
            {% if p.likes is not none %}<span class="badge">♥ {{ p.likes }}</span>{% endif %}
            {% if p.reposts is not none %}<span class="badge">⟳ {{ p.reposts }}</span>{% endif %}
          </div>
        </li>
        {% endfor %}
      </ul>
      {% endif %}
    </article>
    {% endfor %}
  </div>

  {% if x_configured and not accounts %}
  <div class="empty" id="empty-state">No accounts yet — finding the first page…</div>
  {% endif %}

  <div class="pager">
    <button class="btn" id="next-btn" type="button">Next page →</button>
    <span class="hint" id="next-hint"></span>
  </div>
</div>

<script>
(function () {
  "use strict";

  var xConfigured = {{ 'true' if x_configured else 'false' }};
  var hasContent = {{ 'true' if has_content else 'false' }};

  // ---- Follow: intercept the form post, fetch JSON, remove the card ----
  function wireFollows(root) {
    root.querySelectorAll("form.follow-form").forEach(function (form) {
      form.addEventListener("submit", function (ev) {
        ev.preventDefault();
        var card = form.closest(".card");
        var btn = form.querySelector(".follow");
        btn.disabled = true;
        fetch("/api/x/follow", {
          method: "POST",
          headers: { "Accept": "application/json", "Content-Type": "application/x-www-form-urlencoded" },
          body: new URLSearchParams(new FormData(form)).toString()
        }).then(function (r) {
          if (!r.ok) throw new Error("follow failed");
          return r.json();
        }).then(function () {
          removeCard(card);
        }).catch(function () {
          btn.disabled = false;
          form.submit(); // fall back to a full form post so the follow still lands
        });
      });
    });
  }

  function removeCard(card) {
    if (!card) return;
    card.classList.add("removing");
    var done = false;
    function gone() { if (done) return; done = true; card.remove(); }
    card.addEventListener("transitionend", gone, { once: true });
    setTimeout(gone, 600);
  }

  // ---- Background prefetch: poll until the next page is ready ----
  // The /discover GET already kicked the refresh; we just watch for it.
  function pollStatus(tries) {
    if (tries > 40) { // ~3.5 min ceiling, matches the homepage
      var s = document.getElementById("prep-spinner");
      if (!hasContent) s.textContent = "Still finding accounts… reload in a minute.";
      return;
    }
    setTimeout(function () {
      fetch("/api/discover/status", { headers: { "Accept": "application/json" } })
        .then(function (r) { return r.json(); })
        .then(function (d) {
          if (d.next_ready) {
            if (!hasContent) {
              // First visit had nothing to show — reload to promote the page
              // that just finished into view.
              window.location.reload();
            } else {
              revealNext();
            }
          } else {
            pollStatus(tries + 1);
          }
        })
        .catch(function () { pollStatus(tries + 1); });
    }, 5000);
  }

  function revealNext() {
    var btn = document.getElementById("next-btn");
    var hint = document.getElementById("next-hint");
    btn.style.display = "inline-block";
    hint.textContent = "A fresh page of accounts is ready.";
    // Revisiting /discover promotes the prefetched page to view, so "Next" is
    // just a reload. (If you never click it, that page becomes page 1 next time.)
    btn.addEventListener("click", function () { window.location.reload(); });
  }

  wireFollows(document);

  if (xConfigured) {
    if (!hasContent) document.getElementById("prep-spinner").style.display = "block";
    pollStatus(0);
  }
})();
</script>
</body>
</html>
