<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>newslet · emails</title>
<style>
  :root {
    --bg: #f6f6f4; --panel: #ffffff; --fg: #1a1a1a; --muted: #888;
    --border: #e6e6e1; --accent: #0b3d91; --ok: #1a7a3a; --warn: #a06000;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #15151a; --panel: #1d1d22; --fg: #ececec; --muted: #9a9aa3;
      --border: #2c2c33; --accent: #8ab4ff; --ok: #6dc28a; --warn: #d99a4a;
    }
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; background: var(--bg); color: var(--fg); }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; line-height: 1.5; }
  .wrap { max-width: 760px; margin: 0 auto; padding: 24px 16px 64px; }
  header.top { display: flex; align-items: center; justify-content: space-between;
    padding-bottom: 16px; border-bottom: 1px solid var(--border); margin-bottom: 24px; }
  .brand { font-family: Georgia, serif; font-size: 22px; font-weight: 700; letter-spacing: -0.01em; }
  .home { font-size: 13px; color: var(--muted); text-decoration: none; }
  .home:hover { color: var(--fg); text-decoration: underline; }
  section { background: var(--panel); border: 1px solid var(--border); border-radius: 6px; padding: 20px; }
  h2 { margin: 0 0 16px 0; font-size: 18px; }
  ul.emails { list-style: none; padding: 0; margin: 0; }
  ul.emails li { display: flex; align-items: center; justify-content: space-between;
    padding: 10px 0; border-bottom: 1px solid var(--border); gap: 12px; }
  ul.emails li:last-child { border-bottom: none; }
  ul.emails a { color: var(--accent); text-decoration: none; font-weight: 600; }
  ul.emails a:hover { text-decoration: underline; }
  .meta { font-size: 13px; color: var(--muted); }
  .ok { color: var(--ok); }
  .warn { color: var(--warn); }
  .empty { color: var(--muted); font-style: italic; padding: 8px 0; }
</style>
</head>
<body>
<div class="wrap">
  <header class="top">
    <div class="brand">newslet · emails</div>
    <a class="home" href="/admin">← admin</a>
  </header>
  <section>
    <h2>Recent emails</h2>
    {% if issues %}
    <ul class="emails">
      {% for issue in issues %}
      <li>
        <a href="/emails/{{ issue.date|e }}">{{ issue.date|e }}</a>
        <span class="meta">
          {{ issue.picks_count }} picks ·
          {% if issue.sent_at %}<span class="ok">sent</span>{% else %}<span class="warn">unsent</span>{% endif %}
        </span>
      </li>
      {% endfor %}
    </ul>
    {% else %}
    <div class="empty">No emails yet — the first one ships tomorrow at 10:00 UTC.</div>
    {% endif %}
  </section>
</div>
</body>
</html>
